# ============================================================
# Matha School Exam Manager — Server Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ---------------------------------------------------------------
# Aiven PostgreSQL Connection String
# ---------------------------------------------------------------
# Format: postgresql://user:password@host:port/dbname?sslmode=require
#
# IMPORTANT: Aiven's managed Postgres REQUIRES SSL. The ?sslmode=require
# query parameter tells libpq (and Prisma's engine) to enforce SSL.
# Without it, connections will be rejected by the Aiven server.
#
# Where to find this: Aiven Console → Your Service → Overview → Connection Information
# Use the "Service URI" field — it already includes ?sslmode=require.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require"

# ---------------------------------------------------------------
# JWT Secret
# ---------------------------------------------------------------
# Used to sign and verify JSON Web Tokens for authentication.
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_STRONG_RANDOM_SECRET"

# ---------------------------------------------------------------
# Server
# ---------------------------------------------------------------
PORT=5000
NODE_ENV=development
